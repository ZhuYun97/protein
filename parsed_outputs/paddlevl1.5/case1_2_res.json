        {
            "block_label": "paragraph_title",
            "block_content": "De novo design of luciferases for DTZ",
            "block_bbox": [
                73,
                325,
                425,
                349
            ],
            "block_id": 2,
            "block_order": 3,
            "group_id": 2,
            "global_block_id": 32,
            "global_group_id": 32,
            "block_polygon_points": [
                [
                    73.0,
