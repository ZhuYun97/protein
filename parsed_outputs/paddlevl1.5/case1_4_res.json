        {
            "block_label": "paragraph_title",
            "block_content": "Cell imaging and multiplexed bioassay",
            "block_bbox": [
                74,
                1400,
                441,
                1425
            ],
            "block_id": 9,
            "block_order": 2,
            "group_id": 9,
            "global_block_id": 77,
            "global_group_id": 77,
            "block_polygon_points": [
                [
